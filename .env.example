SERVER_PORT=8080

# =========================================================
# Database
# =========================================================
# 회사/운영 환경에서 Oracle을 사용할 때는 아래 Oracle 설정을 활성화하세요.
DB_DRIVER_CLASS_NAME=oracle.jdbc.OracleDriver
DB_URL=jdbc:oracle:thin:@localhost:1521/XEPDB1
DB_USERNAME=your_oracle_username
DB_PASSWORD=your_oracle_password
JPA_DATABASE_PLATFORM=org.hibernate.dialect.OracleDialect

# 개인/로컬 개발 환경에서 MySQL을 사용할 때는 위 Oracle 설정을 주석 처리하고
# 아래 MySQL 설정을 활성화하세요.
# DB_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
# DB_URL=jdbc:mysql://localhost:3306/safemask?serverTimezone=Asia/Seoul&characterEncoding=UTF-8&useSSL=false&allowPublicKeyRetrieval=true
# DB_USERNAME=your_mysql_username
# DB_PASSWORD=your_mysql_password
# JPA_DATABASE_PLATFORM=org.hibernate.dialect.MySQLDialect

JPA_DDL_AUTO=validate
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

OPENAI_API_KEY=
SAFEMASK_AI_MODEL=gpt-4o-mini
MASKING_MAPPING_TTL=24h
MAX_FILE_SIZE=20MB
MAX_REQUEST_SIZE=25MB


JWT_SECRET=change-me-to-a-random-string-of-at-least-32-characters
JWT_ACCESS_TOKEN_EXPIRATION=3600000
JWT_REFRESH_TOKEN_EXPIRATION=1209600000
